# ============================================
# Configuration PROD
# ============================================
NODE_ENV=production
VITE_APP_ENV=production
VITE_APP_NAME=TaskFlow
VITE_API_URL=https://api.taskflow.example.com/api
VITE_APP_VERSION=1.0.0

# Serveur
PORT=80
HOST=0.0.0.0

# Base de données (secrets injectés via CI/CD)
DB_HOST=${DB_HOST_SECRET}
DB_PORT=5432
DB_NAME=taskflow_prod
DB_USER=${DB_USER_SECRET}
DB_PASSWORD=${DB_PASSWORD_SECRET}

# Logging
LOG_LEVEL=warn
